  "keyFeatures": [
    "Hooks-based API with useJsApiLoader and useGoogleMap",
    "Full TypeScript support with complete type definitions",
    "React 19 compatible with backward compatibility to React 16.8+",
    "Tree-shakeable components for optimal bundle size",
    "SSR friendly for Next.js, Remix, and other frameworks",
    "Comprehensive component library for maps, markers, overlays, and services",
    "Marker clustering support with @googlemaps/markerclusterer integration",
    "Drawing tools including polygons, circles, polylines, and rectangles",
    "Places API integration with autocomplete and search",
    "Directions and distance matrix services",
    "Street View panorama support",
    "Custom overlay and info window components"
  ],
